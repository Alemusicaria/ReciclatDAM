APP_NAME=ReciclatDAM
APP_ENV=local
APP_KEY=base64:YOUR_BASE64_ENCODED_32_BYTE_KEY_HERE
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=ca
APP_FALLBACK_LOCALE=ca
APP_FAKER_LOCALE=ca_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=production

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=reclicat_bbdd
DB_USERNAME=reclicat_user
DB_PASSWORD=SECURE_DB_PASSWORD_HERE

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=smtp
# Free SMTP option (Brevo free plan)
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your_brevo_login
MAIL_PASSWORD=your_brevo_smtp_key
# Use your verified sender email in Brevo
MAIL_FROM_ADDRESS="contacte@reciclatdam.com"
MAIL_FROM_NAME="${APP_NAME}"
# Optional: force all outgoing emails to one inbox (local/testing)
MAIL_TO_ADDRESS=
MAIL_TO_NAME=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/login/google/callback

GOOGLE_MAPS_ENABLED=false
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=

UPLOAD_SCAN_COMMAND=
